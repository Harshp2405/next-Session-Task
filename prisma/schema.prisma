model user {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  role          String      @default("Intern")
  createdAt     DateTime  @default(now())
  college       String?
  gender        String

  departmentId  String?
  department    Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])
  isHead        Boolean   @default(false)

  headOf        Department? @relation("DepartmentHead")

  accounts      Account[]
  sessions      Session[]
}

model Department {
  id        String   @id @default(uuid())
  name      String

  headId    String   @unique
  head      user     @relation("DepartmentHead", fields: [headId], references: [id])

  members   user[]   @relation("DepartmentMembers")

  createdAt DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

